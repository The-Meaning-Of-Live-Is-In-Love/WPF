<Window x:Class = "Game.MainWindow"
    xmlns = "http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x = "http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d = "http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc = "http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:local = "clr-namespace:Game"
    mc:Ignorable = "d"
    KeyDown = "Movement"
    Title = "Game" Height = "1080" Width = "1920">
    <Window.Resources>
        <SolidColorBrush x:Key = "WindowBrush" Color = "Black"/>
    </Window.Resources>
    <Window.Style>
        <Style TargetType = "{x:Type Window}">
            <Setter Property = "Background" Value = "{StaticResource WindowBrush}"/>
        </Style>
    </Window.Style>
    <Canvas Height = "0" Width = "0">
        <Ellipse Name = "Player_Light_1" Width = "30" Height = "30" Fill = "LightGray" Canvas.Left = "0" Canvas.Top = "0" Margin = "-100000"/>
        <Ellipse Name = "Player_Light_2" Width = "20" Height = "20" Fill = "White" Canvas.Left = "0" Canvas.Top = "0" Margin = "-100000"/>
        <Ellipse Name = "Player" Width = "10" Height = "10" Fill = "black" Canvas.Left = "0" Canvas.Top = "0" Margin = "-100000"/>
    </Canvas>
</Window>
